# ─── Admin Authentication ──────────────────────────────────────────
# Password to log in to /admin
ADMIN_PASSWORD=change-this-password

# Random secret token stored in the cookie (generate a long random string)
# Example: openssl rand -hex 32
ADMIN_SECRET_TOKEN=change-this-to-a-random-secret-token

# ─── WhatsApp ──────────────────────────────────────────────────────
# Your WhatsApp business number (international format, no +)
NEXT_PUBLIC_WHATSAPP_NUMBER=212600000000

# ─── Meta Pixel (optional) ────────────────────────────────────────
# Your Facebook/Meta Pixel ID (leave empty if not set up yet)
NEXT_PUBLIC_META_PIXEL_ID=

# ─── Site URL ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://veluna.ma
