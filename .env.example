# ═══════════════════════════════════════════════════════════════════════════════
# Veluna Store — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to frontend/.env.local for local development.
# In Easypanel, add these as environment variables in the service settings.
# NEVER commit a file that contains real values.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Admin Authentication ──────────────────────────────────────────────────────
# Password to log in to the /admin dashboard.
ADMIN_PASSWORD=change-this-to-a-strong-password

# Long random secret stored in the session cookie.
# Generate with: openssl rand -hex 32
ADMIN_SECRET_TOKEN=change-this-to-a-long-random-secret

# ── WhatsApp ─────────────────────────────────────────────────────────────────
# Your WhatsApp Business number in international format (no + sign, no spaces).
# Example: 212612345678
NEXT_PUBLIC_WHATSAPP_NUMBER=212600000000

# ── Meta / Facebook Pixel (optional) ─────────────────────────────────────────
# Leave empty if you haven't set up Meta Pixel yet.
NEXT_PUBLIC_META_PIXEL_ID=

# ── Site URL ─────────────────────────────────────────────────────────────────
# Full URL of your store (no trailing slash).
# Local:      http://localhost:3000
# Production: https://veluna.ma
NEXT_PUBLIC_SITE_URL=https://veluna.ma

# ── Node environment ─────────────────────────────────────────────────────────
# Set to "production" on the server.
NODE_ENV=production
