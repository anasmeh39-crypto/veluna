# ── Database ──────────────────────────────────────────────────────────────────
# Veluna uses SQLite (file-based) — no DATABASE_URL needed.
# The database is auto-created at /app/data/veluna.db on first request.
# Mount a persistent volume at /app/data in Easypanel (see backend/EASYPANEL_DEPLOYMENT.md).

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://veluna.ma
NODE_ENV=production

# ── Admin Auth ────────────────────────────────────────────────────────────────
ADMIN_PASSWORD=
ADMIN_SECRET_TOKEN=

# ── WhatsApp ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ── Meta / Facebook ───────────────────────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# ── TikTok ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=

# ── Google Sheets (order webhook — optional) ──────────────────────────────────
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
