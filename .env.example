# ═══════════════════════════════════════════════════════════════════════════════
# Veluna Store — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════
#
# Architecture: ONE single Next.js 14 app — no separate backend server.
# Port: 3000 (set this in Easypanel service port field)
#
# All variables below go into the SAME Easypanel service ("backend").
# NEXT_PUBLIC_ variables are sent to the browser (embedded at build time).
# All other variables stay server-side only.
#
# Local dev: copy this file to frontend/.env.local and fill in values.
# Production: add these in Easypanel → veluna → backend → Environment tab.
# ═══════════════════════════════════════════════════════════════════════════════


# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Admin Auth (SERVER ONLY — never expose to browser) ───────────────────────
# Password to log in at /admin
ADMIN_PASSWORD=

# Random secret stored in session cookie — generate: openssl rand -hex 32
ADMIN_SECRET_TOKEN=

# ── Database ──────────────────────────────────────────────────────────────────
# Currently using SQLite (file at /app/data/veluna.db) — DATABASE_URL not needed.
# When migrating to PostgreSQL, uncomment and fill this in:
# DATABASE_URL=postgres://user:password@veluna-db:5432/veluna?sslmode=disable

# ── Public site URL (sent to browser) ────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://veluna.ma

# ── WhatsApp (sent to browser) ───────────────────────────────────────────────
# International format, no + sign, no spaces. Example: 212612345678
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ── Meta / Facebook (sent to browser) ────────────────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=
META_ACCESS_TOKEN=
META_TEST_EVENT_CODE=

# ── TikTok (sent to browser) ──────────────────────────────────────────────────
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
TIKTOK_ACCESS_TOKEN=

# ── Google Sheets order webhook (optional) ────────────────────────────────────
GOOGLE_SHEETS_WEBHOOK_URL=
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
