data/*.db
data/*.db-shm
data/*.db-wal
frontend/data/*.db
frontend/data/*.db-shm
frontend/data/*.db-wal

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tgz
.vercel
