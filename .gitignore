# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Next.js ───────────────────────────────────────────────────────────────────
.next/
out/
build/
dist/

# ── Environment variables (NEVER commit real secrets) ─────────────────────────
.env
.env.local
.env.*.local
.env.production
.env.production.local

